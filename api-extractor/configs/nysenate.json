{
  "source_id": "nysenate",
  "description": "New York State Laws via NY Senate Open Legislation API",
  "jurisdiction": "ny",

  "defaultBaseUrl": "https://legislation.nysenate.gov/api/3",
  "baseUrlEnv": "NYSENATE_BASE_URL",
  "apiKeyEnv": "NYSENATE_API_KEY",

  "rate": {
    "rpsEnv": "NYSENATE_RATE_RPS",
    "defaultRps": 3
  },

  "retry": {
    "maxEnv": "NYSENATE_RETRY_MAX",
    "defaultMax": 5,
    "baseDelayMs": 500
  },

  "endpoints": {
    "lawsIndex": "/laws",
    "lawStructure": "/laws/{lawId}",
    "document": "/laws/{lawId}/{docId}",
    "subDocuments": "/laws/{lawId}/{docId}/documents",
    "rootDocuments": "/laws/{lawId}/documents"
  },

  "response": {
    "dataField": ["result", "items"],
    "totalPagesField": ["result", "offsetStart"]
  },

  "mapping": {
    "lawTypeField": ["lawType"],
    "sectionIdField": ["locationId", "docId"],
    "sectionNumField": ["lawSection", "locationId"],
    "sectionHeadingField": ["title"],
    "sectionTextPlainField": ["text"],
    "sectionTextHtmlField": [],
    "effectiveStartField": ["activeDate"],
    "effectiveEndField": []
  },

  "database": {
    "host": "localhost",
    "port": 5433,
    "user": "postgres",
    "password": "postgres",
    "database": "ny_reporter_dev"
  }
}
