# Track B / B1 — caselaw-merge connection config.
#
# All four source/target DBs live on system Postgres (port 5432), per the root
# CLAUDE.md "Local DB Access for Claude" section. The merged DB does not exist
# yet — phase 1 creates it via the ADMIN connection.

# ---------------------------------------------------------------------------
# Source DBs — read-only is sufficient. The `claude` role from the root
# CLAUDE.md works as long as the source DBs have it granted (they do).
# ---------------------------------------------------------------------------
SOURCE_NY_SUPREME_URL=postgres://claude:claude@localhost:5432/ny_reporter
SOURCE_NY_APPELLATE_URL=postgres://claude:claude@localhost:5432/ny_appellate_division
SOURCE_NY_TRIAL_URL=postgres://claude:claude@localhost:5432/ny_trial_courts

# ---------------------------------------------------------------------------
# Admin connection — superuser (or anyone with CREATEDB) pointed at the
# `postgres` maintenance DB. Used exclusively by phase 1 to issue
# `CREATE DATABASE ny_caselaw`. Not used after bootstrap.
# ---------------------------------------------------------------------------
ADMIN_URL=postgres://shambles@localhost:5432/postgres

# ---------------------------------------------------------------------------
# Target DB — what the merged caselaw lives in. The role here owns the DDL
# and writes all merged rows. Pointed at the database name that phase 1
# creates (must match MERGE_TARGET_DB below).
# ---------------------------------------------------------------------------
TARGET_URL=postgres://shambles@localhost:5432/ny_caselaw
MERGE_TARGET_DB=ny_caselaw

# ---------------------------------------------------------------------------
# Optional. Default INFO. Set DEBUG to log every SQL statement.
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
